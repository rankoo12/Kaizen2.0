# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://kaizen:kaizen@localhost:5432/kaizen

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Vector Database (Pinecone) ───────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=kaizen
PINECONE_ENVIRONMENT=us-east-1-aws

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to 'openai' or 'anthropic'. The gateway abstracts the rest.
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# ─── Object Storage (Cloudflare R2 or AWS S3) ─────────────────────────────────
S3_BUCKET=kaizen-screenshots
# For Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
# For AWS S3: leave this blank to use the default regional endpoint
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-secure-random-64-byte-hex-string

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Observability ────────────────────────────────────────────────────────────
# OpenTelemetry collector endpoint (OTLP/HTTP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# ─── Worker ───────────────────────────────────────────────────────────────────
# Number of concurrent Playwright jobs per worker container
WORKER_CONCURRENCY=4
# Maximum wall-clock time for a single test run job (ms)
MAX_JOB_TIMEOUT_MS=300000

# ─── LLM Gateway ──────────────────────────────────────────────────────────────
# How long to cache identical LLM prompt→response pairs in Redis (seconds)
LLM_PROMPT_CACHE_TTL_SECONDS=86400
# How long to keep resolved selectors in the Redis hot cache (seconds)
SELECTOR_CACHE_TTL_SECONDS=3600
